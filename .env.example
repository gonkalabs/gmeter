# Copy this file to .env and fill in provider keys locally.
# Never commit real API keys.
GONKA_API_KEY=
GONKA_BASE_URL=https://proxy.gonka.gg/v1
GONKAGATE_API_KEY=
GONKAGATE_BASE_URL=https://api.gonkagate.com/v1
MINGLES_API_KEY=
MINGLES_BASE_URL=https://gonka-gateway.mingles.ai/v1
GONKA_API_ORG_API_KEY=
GONKA_API_ORG_BASE_URL=https://api.gonka-api.org/v1
HYPERFUSION_API_KEY=
HYPERFUSION_BASE_URL=https://api.hyperfusion.io/v1
GONKASCAN_API_KEY=
GONKASCAN_BASE_URL=https://api.gonkascan.com/v1
BROKERS_CONFIG_PATH=brokers.json
# BROKERS_CONFIG_JSON={"brokers":[]}
PROBE_INTERVAL_MINUTES=10
LIMITS_INTERVAL_MINUTES=60
MIN_OUTPUT_TOKENS=10000
PUBLIC_READ_ONLY=true
RUN_PROBE_ON_STARTUP=true
RUN_LIMITS_ON_STARTUP=false
